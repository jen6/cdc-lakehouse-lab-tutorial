aws_region  = "ap-northeast-2"
project     = "cdc-lakehouse-tutorial"
environment = "sandbox"

repository_url = "git@github.com:YOUR_GITHUB_OWNER/YOUR_REPO.git"

# Cost-controlled MVP defaults.
msk_mode            = "provisioned"
az_count             = 2
msk_broker_count     = 2
msk_instance_type    = "kafka.t3.small"
msk_ebs_volume_size  = 100
rds_instance_class   = "db.t4g.medium"
rds_allocated_storage = 100

eks_node_instance_types = ["m6i.large"]
eks_node_min_size       = 1
eks_node_desired_size   = 2
eks_node_max_size       = 4

# Leave true for quick lab teardown. Set false and provide a manual snapshot
# workflow when you want source data to survive destroy.
rds_skip_final_snapshot = true
